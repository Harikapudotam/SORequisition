<mvc:View
    controllerName="ust.soreq.controller.Detail"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form">

    <Page id="_IDGenPage2"
        title="Requisition Detail"
        showNavButton="true"
        navButtonPress="onNavBack">

        <content>

            <VBox id="_IDGenVBox1" class="sapUiSmallMargin">

                <ObjectHeader id="_IDGenObjectHeader"
                    title="{requisitionNo}"
                    number="{targetPrice}"
                    numberUnit="{currency}"
                    intro="Sales Order Requisition">

                    <statuses>
                        <ObjectStatus id="_IDGenObjectStatus1"
                            title="Status"
                            text="{status}"
                            state="{= ${status} === 'COMPLETED' ? 'Success' : ${status} === 'ON_HOLD' ? 'Warning' : ${status} === 'SUBMITTED' ? 'Information' : 'None' }"/>
                    </statuses>

                    <attributes>
                        <ObjectAttribute id="_IDGenObjectAttribute" title="Version" text="{version}"/>
                        <ObjectAttribute id="_IDGenObjectAttribute1" title="Customer" text="{customerName}"/>
                        <ObjectAttribute id="_IDGenObjectAttribute2" title="Buyer" text="{buyerName}"/>
                        <ObjectAttribute id="_IDGenObjectAttribute3" title="Plant" text="{plant}"/>
                    </attributes>

                </ObjectHeader>

                <IconTabBar id="_IDGenIconTabBar" class="sapUiSmallMarginTop">

                    <items>

                        <IconTabFilter id="_IDGenIconTabFilter" text="General Info" key="general">
                            <f:SimpleForm id="_IDGenSimpleForm"
                                editable="false"
                                layout="ResponsiveGridLayout"
                                labelSpanXL="3"
                                labelSpanL="3"
                                labelSpanM="3"
                                labelSpanS="12"
                                columnsXL="2"
                                columnsL="2"
                                columnsM="1">

                                <Label id="_IDGenLabel" text="Requisition No"/>
                                <Text id="_IDGenText15" text="{requisitionNo}"/>

                                <Label id="_IDGenLabel1" text="Status"/>
                                <Text id="_IDGenText16" text="{status}"/>

                                <Label id="_IDGenLabel2" text="Customer ID"/>
                                <Text id="_IDGenText17" text="{customerID}"/>

                                <Label id="_IDGenLabel3" text="Customer Name"/>
                                <Text id="_IDGenText18" text="{customerName}"/>

                                <Label id="_IDGenLabel4" text="Buyer ID"/>
                                <Text id="_IDGenText19" text="{buyerID}"/>

                                <Label id="_IDGenLabel5" text="Buyer Name"/>
                                <Text id="_IDGenText20" text="{buyerName}"/>

                                <Label id="_IDGenLabel6" text="Material"/>
                                <Text id="_IDGenText21" text="{material}"/>

                                <Label id="_IDGenLabel7" text="Material Description"/>
                                <Text id="_IDGenText22" text="{materialDescription}"/>

                                <Label id="_IDGenLabel8" text="Quantity"/>
                                <Text id="_IDGenText23" text="{quantity} {unit}"/>

                                <Label id="_IDGenLabel9" text="Plant"/>
                                <Text id="_IDGenText24" text="{plant}"/>

                                <Label id="_IDGenLabel10" text="Requested Delivery Date"/>
                                <Text id="_IDGenText25" text="{requestedDeliveryDate}"/>

                                <Label id="_IDGenLabel11" text="Justification"/>
                                <Text id="_IDGenText26" text="{justification}"/>

                            </f:SimpleForm>
                        </IconTabFilter>

                        <IconTabFilter id="_IDGenIconTabFilter1" text="Pricing" key="pricing">
                            <f:SimpleForm id="_IDGenSimpleForm1"
                                editable="false"
                                layout="ResponsiveGridLayout">

                                <Label id="_IDGenLabel12" text="Target Price"/>
                                <Text id="_IDGenText27" text="{targetPrice}"/>

                                <Label id="_IDGenLabel13" text="Currency"/>
                                <Text id="_IDGenText28" text="{currency}"/>

                            </f:SimpleForm>
                        </IconTabFilter>

                        <IconTabFilter id="_IDGenIconTabFilter2" text="Items" key="items">
                            <Table
                                id="itemsTable"
                                growing="true"
                                mode="SingleSelectMaster"
                                items="{items}"
                                itemPress="onItemPress">

                                <columns>
                                    <Column id="_IDGenColumn8">
                                        <Text id="_IDGenText29" text="Item No"/>
                                    </Column>
                                    <Column id="_IDGenColumn9">
                                        <Text id="_IDGenText30" text="Material"/>
                                    </Column>
                                    <Column id="_IDGenColumn10">
                                        <Text id="_IDGenText31" text="Description"/>
                                    </Column>
                                    <Column id="_IDGenColumn11">
                                        <Text id="_IDGenText32" text="Quantity"/>
                                    </Column>
                                    <Column id="_IDGenColumn12">
                                        <Text id="_IDGenText33" text="Target Price"/>
                                    </Column>
                                    <Column id="_IDGenColumn13">
                                        <Text id="_IDGenText34" text="Delivery Date"/>
                                    </Column>
                                </columns>

                                <items>
                                    <ColumnListItem id="_IDGenColumnListItem1" type="Navigation">
                                        <cells>
                                            <Text id="_IDGenText35" text="{itemNo}"/>
                                            <Text id="_IDGenText36" text="{material}"/>
                                            <Text id="_IDGenText37" text="{materialDescription}"/>
                                            <Text id="_IDGenText38" text="{quantity} {unit}"/>
                                            <Text id="_IDGenText39" text="{targetPrice}"/>
                                            <Text id="_IDGenText40" text="{requestedDeliveryDate}"/>
                                        </cells>
                                    </ColumnListItem>
                                </items>

                            </Table>
                        </IconTabFilter>

                        <IconTabFilter id="_IDGenIconTabFilter3" text="Pending Change" key="pending">
                            <f:SimpleForm id="_IDGenSimpleForm2"
                                editable="false"
                                layout="ResponsiveGridLayout">

                                <Label id="_IDGenLabel14" text="Pending Version Before"/>
                                <Text id="_IDGenText41" text="{pendingVersionBefore}"/>

                                <Label id="_IDGenLabel15" text="Pending Requested By"/>
                                <Text id="_IDGenText42" text="{pendingRequestedBy}"/>

                                <Label id="_IDGenLabel16" text="Pending Requested At"/>
                                <Text id="_IDGenText43" text="{pendingRequestedAt}"/>

                                <Label id="_IDGenLabel17" text="Pending Summary"/>
                                <Text id="_IDGenText44" text="{pendingSummary}"/>

                            </f:SimpleForm>
                        </IconTabFilter>

                    </items>

                </IconTabBar>

            </VBox>

        </content>
    </Page>

</mvc:View>