<mvc:View
    controllerName="ust.so.soreq.controller.Overview"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">

    <Page id="_IDGenPage1" title="Sales Order Requisitions">
        <content>

            <VBox id="_IDGenVBox" class="sapUiSmallMargin">

                <SearchField id="_IDGenSearchField"
                    width="100%"
                    placeholder="Search by requisition, customer, buyer, material or status"
                    liveChange="onSearch"/>

                <Table
                    id="requisitionTable"
                    class="sapUiSmallMarginTop"
                    mode="SingleSelectMaster"
                    growing="true"
                    growingScrollToLoad="true"
                    items="{/SalesOrderRequisition}"
                    itemPress="onItemPress">

                    <columns>
                        <Column id="_IDGenColumn">
                            <Text id="_IDGenText" text="Requisition No"/>
                        </Column>
                        <Column id="_IDGenColumn1">
                            <Text id="_IDGenText1" text="Version"/>
                        </Column>
                        <Column id="_IDGenColumn2">
                            <Text id="_IDGenText2" text="Status"/>
                        </Column>
                        <Column id="_IDGenColumn3">
                            <Text id="_IDGenText3" text="Customer"/>
                        </Column>
                        <Column id="_IDGenColumn4">
                            <Text id="_IDGenText4" text="Buyer"/>
                        </Column>
                        <Column id="_IDGenColumn5">
                            <Text id="_IDGenText5" text="Material"/>
                        </Column>
                        <Column id="_IDGenColumn6">
                            <Text id="_IDGenText6" text="Quantity"/>
                        </Column>
                        <Column id="_IDGenColumn7">
                            <Text id="_IDGenText7" text="Plant"/>
                        </Column>
                    </columns>

                    <items>
                        <ColumnListItem id="_IDGenColumnListItem" type="Navigation">
                            <cells>
                                <Text id="_IDGenText8" text="{requisitionNo}"/>
                                <Text id="_IDGenText9" text="{version}"/>
                                <ObjectStatus id="_IDGenObjectStatus"
                                    text="{status}"
                                    state="{= ${status} === 'COMPLETED' ? 'Success' : ${status} === 'ON_HOLD' ? 'Warning' : ${status} === 'SUBMITTED' ? 'Information' : 'None' }"/>
                                <Text id="_IDGenText10" text="{customerName}"/>
                                <Text id="_IDGenText11" text="{buyerName}"/>
                                <Text id="_IDGenText12" text="{material}"/>
                                <Text id="_IDGenText13" text="{quantity} {unit}"/>
                                <Text id="_IDGenText14" text="{plant}"/>
                            </cells>
                        </ColumnListItem>
                    </items>

                </Table>

            </VBox>

        </content>
    </Page>

</mvc:View>